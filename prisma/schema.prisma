generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  phone     String   @unique
  username  String?  @unique
  passwordHash String?
  instagramHandle String? @unique
  snapchatHandle  String? @unique
  primaryCategory LocationCategory @default(COLLEGE)
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  college       CollegeProfile?
  school        SchoolProfile?
  workplace     WorkplaceProfile?
  gym           GymProfile?
  neighbourhood NeighbourhoodProfile?

  sentConfessions     Confession[] @relation("SentConfessions")
  receivedConfessions Confession[] @relation("ReceivedConfessions")

  confessionPageUnlocked Boolean      @default(false)
  unlockedCards          UnlockedCard[]
  otpSessions            OtpSession[]
}

model CollegeProfile {
  id            String @id @default(cuid())
  userId        String @unique
  user          User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  collegeName   String
  pinCode       String
  course        String
  branch        String
  yearOfPassing Int
  section       String
  fullName      String
}

model SchoolProfile {
  id               String @id @default(cuid())
  userId           String @unique
  user             User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  schoolName       String
  pinCode          String
  board            String
  yearOfCompletion Int
  section          String
  fullName         String
}

model WorkplaceProfile {
  id           String @id @default(cuid())
  userId       String @unique
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName  String
  department   String
  city         String
  buildingName String
  fullName     String
}

model GymProfile {
  id       String    @id @default(cuid())
  userId   String    @unique
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  gymName  String
  city     String
  pinCode  String
  timing   GymTiming
  fullName String
}

model NeighbourhoodProfile {
  id           String @id @default(cuid())
  userId       String @unique
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  state        String
  city         String
  pinCode      String
  premisesName String
  fullName     String
}

model Confession {
  id          String           @id @default(cuid())
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  senderId    String
  sender      User             @relation("SentConfessions", fields: [senderId], references: [id])
  targetId    String?
  target      User?            @relation("ReceivedConfessions", fields: [targetId], references: [id])
  targetPhone String?
  message     String
  location    LocationCategory
  matchDetails Json
  status      ConfessionStatus @default(PENDING)
  reply       String?
  repliedAt   DateTime?
  expiresAt   DateTime
  mutualDetected        Boolean  @default(false)
  senderRevealConsent   Boolean  @default(false)
  targetRevealConsent   Boolean  @default(false)
  revealedAt            DateTime?
  unlockedBy  UnlockedCard[]
}

model UnlockedCard {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  confessionId String
  confession   Confession @relation(fields: [confessionId], references: [id])
  unlockedAt   DateTime   @default(now())

  @@unique([userId, confessionId])
}

model OtpSession {
  id        String   @id @default(cuid())
  phone     String
  otp       String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
}

enum GymTiming {
  MORNING
  EVENING
  BOTH
}

enum LocationCategory {
  COLLEGE
  SCHOOL
  WORKPLACE
  GYM
  NEIGHBOURHOOD
}

enum ConfessionStatus {
  PENDING
  DELIVERED
  OPENED
  REPLIED
  GHOSTED
  EXPIRED
}
