generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  publicCode String? @unique
  phone     String   @unique
  username  String?  @unique
  passwordHash String?
  dateOfBirth DateTime?
  instagramHandle String? @unique
  snapchatHandle  String? @unique
  profileSearchCount Int?
  primaryCategory LocationCategory @default(COLLEGE)
  gender    Gender   @default(OTHER)
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  college       CollegeProfile?
  school        SchoolProfile?
  workplace     WorkplaceProfile?
  gym           GymProfile?
  neighbourhood NeighbourhoodProfile?

  sentConfessions     Confession[] @relation("SentConfessions")
  receivedConfessions Confession[] @relation("ReceivedConfessions")

  confessionPageUnlocked Boolean      @default(false)
  unlockedCards          UnlockedCard[]
  profileInsightsViewed  UnlockedProfileInsight[] @relation("ProfileInsightViewer")
  profileInsightsOwned   UnlockedProfileInsight[] @relation("ProfileInsightTarget")
  otpSessions            OtpSession[]
  payments               Payment[]
  visitSessions          VisitSession[]
  activities             UserActivity[]
  pendingSocialOwnershipRequests PendingSocialOwnershipRequest[]
  notificationAudienceCounters NotificationAudienceCounter[]
  claimedShadowProfiles ShadowProfile[]
  marketingContacts MarketingContact[] @relation("MarketingContactUser")
  marketingRevenueSnapshots MarketingRevenueSnapshot[] @relation("MarketingRevenueUser")
}

model PendingProfileSearchCount {
  id        String                   @id @default(cuid())
  kind      PendingProfileSearchKind
  value     String
  count     Int                      @default(0)
  createdAt DateTime                 @default(now())
  updatedAt DateTime                 @updatedAt

  @@unique([kind, value])
}

model ShadowProfile {
  id                String                   @id @default(cuid())
  kind              PendingProfileSearchKind
  value             String
  location          LocationCategory?
  displayName       String
  profileDetails    Json
  searchCount       Int                      @default(0)
  claimedByUserId   String?
  claimedByUser     User?                    @relation(fields: [claimedByUserId], references: [id], onDelete: SetNull)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  confessions       Confession[]

  @@index([kind, value])
  @@index([claimedByUserId])
}

model CollegeProfile {
  id            String @id @default(cuid())
  userId        String @unique
  user          User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  collegeName   String
  pinCode       String
  course        String
  branch        String
  yearOfPassing Int
  section       String
  fullName      String
}

model SchoolProfile {
  id               String @id @default(cuid())
  userId           String @unique
  user             User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  schoolName       String
  pinCode          String
  board            String
  yearOfCompletion Int
  section          String
  fullName         String
}

model WorkplaceProfile {
  id           String @id @default(cuid())
  userId       String @unique
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName  String
  department   String
  city         String
  buildingName String
  fullName     String
}

model GymProfile {
  id       String    @id @default(cuid())
  userId   String    @unique
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  gymName  String
  city     String
  pinCode  String
  timing   GymTiming
  fullName String
}

model NeighbourhoodProfile {
  id           String @id @default(cuid())
  userId       String @unique
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  state        String
  city         String
  pinCode      String
  homeNumber   String
  premisesName String
  fullName     String
}

model Confession {
  id          String           @id @default(cuid())
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  senderId    String
  sender      User             @relation("SentConfessions", fields: [senderId], references: [id])
  targetId    String?
  target      User?            @relation("ReceivedConfessions", fields: [targetId], references: [id])
  targetPhone String?
  shadowProfileId String?
  shadowProfile ShadowProfile?   @relation(fields: [shadowProfileId], references: [id], onDelete: SetNull)
  isSelfConfession Boolean     @default(false)
  billingCategory ConfessionBillingCategory @default(CONFESSION_TO_OTHERS)
  billingState ConfessionBillingState @default(PAID)
  selfGenderOverride Gender?
  message     String
  location    LocationCategory
  matchDetails Json
  status      ConfessionStatus @default(PENDING)
  reply       String?
  repliedAt   DateTime?
  expiresAt   DateTime
  mutualDetected        Boolean  @default(false)
  senderRevealConsent   Boolean  @default(false)
  targetRevealConsent   Boolean  @default(false)
  revealedAt            DateTime?
  unlockedBy  UnlockedCard[]

  @@index([senderId, createdAt])
  @@index([targetId, createdAt])
  @@index([senderId, targetId, isSelfConfession])
  @@index([targetId, status, createdAt])
  @@index([status, createdAt])
  @@index([targetPhone])
  @@index([shadowProfileId])
  @@index([expiresAt])
}

model UnlockedCard {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  confessionId String
  confession   Confession @relation(fields: [confessionId], references: [id])
  unlockedAt   DateTime   @default(now())

  @@unique([userId, confessionId])
}

model UnlockedProfileInsight {
  id           String   @id @default(cuid())
  viewerId     String
  viewer       User     @relation("ProfileInsightViewer", fields: [viewerId], references: [id])
  targetUserId String
  targetUser   User     @relation("ProfileInsightTarget", fields: [targetUserId], references: [id])
  unlockedAt   DateTime @default(now())
  
  @@index([viewerId, targetUserId])
  @@index([targetUserId])
}

model OtpSession {
  id        String   @id @default(cuid())
  phone     String
  requestIp String?
  otp       String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone, createdAt])
  @@index([requestIp, createdAt])
  @@index([phone, verified, createdAt])
  @@index([phone, verified, expiresAt])
}

model StaffUser {
  id           String            @id @default(cuid())
  name         String
  username     String            @unique
  passwordHash String
  role         StaffRole
  status       StaffStatus       @default(ACTIVE)
  permissions  StaffPermission[] @default([])
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  managedPayments Payment[] @relation("PaymentManager")
  marketingAgentProfile MarketingAgentProfile?
}

model Payment {
  id                   String        @id @default(cuid())
  userId               String
  user                 User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  type                 PaymentType
  status               PaymentStatus @default(SUCCESS)
  amount               Int
  gateway              String?
  gatewayTransactionId String?
  metadata             Json?
  managedByStaffId     String?
  managedByStaff       StaffUser?    @relation("PaymentManager", fields: [managedByStaffId], references: [id], onDelete: SetNull)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  marketingRevenueSnapshot MarketingRevenueSnapshot?

  @@index([userId, type, createdAt])
  @@index([userId, status, createdAt])
  @@index([status, createdAt])
  @@unique([gateway, gatewayTransactionId])
}

model MarketingAgentProfile {
  id                   String   @id @default(cuid())
  staffUserId          String   @unique
  staffUser            StaffUser @relation(fields: [staffUserId], references: [id], onDelete: Cascade)
  agentId              String   @unique
  contactLimit         Int
  revenueSharePercent  Float
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  contacts             MarketingContact[]
  tags                 MarketingAgentTag[]
  revenueSnapshots     MarketingRevenueSnapshot[]
}

model MarketingGlobalTag {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  agentTags MarketingAgentTag[]
}

model MarketingAgentTag {
  id             String   @id @default(cuid())
  profileId      String
  profile        MarketingAgentProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name           String
  sourceGlobalTagId String?
  sourceGlobalTag MarketingGlobalTag? @relation(fields: [sourceGlobalTagId], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  contactTags    MarketingContactTag[]

  @@unique([profileId, name])
  @@index([profileId])
}

model MarketingContact {
  id                          String   @id @default(cuid())
  profileId                   String
  profile                     MarketingAgentProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  userId                      String?
  user                        User?    @relation("MarketingContactUser", fields: [userId], references: [id], onDelete: SetNull)
  name                        String
  countryCode                 String
  phone                       String
  phoneNormalized             String   @unique
  notes                       String?
  confessionsSent             Int      @default(0)
  lockedReceivedConfessions   Int      @default(0)
  isDeleted                   Boolean  @default(false)
  deletedAt                   DateTime?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
  tags                        MarketingContactTag[]
  revenueSnapshots            MarketingRevenueSnapshot[]
  editLogs                    MarketingContactEditLog[]

  @@index([profileId, isDeleted])
  @@index([userId])
}

model MarketingContactTag {
  contactId String
  tagId     String
  contact   MarketingContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag       MarketingAgentTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
  @@index([tagId])
}

model MarketingContactEditLog {
  id          String   @id @default(cuid())
  contactId   String
  contact     MarketingContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  changedAt   DateTime @default(now())
  changedKeys String[]

  @@index([contactId, changedAt])
}

model MarketingRevenueSnapshot {
  id                    String   @id @default(cuid())
  paymentId             String   @unique
  payment               Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  profileId             String
  profile               MarketingAgentProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  contactId             String
  contact               MarketingContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  userId                String
  user                  User @relation("MarketingRevenueUser", fields: [userId], references: [id], onDelete: Cascade)
  grossAmount           Int
  revenueSharePercent   Float
  agentShareAmount      Float
  purchaseType          PaymentType
  purchaseCreatedAt     DateTime
  monthKey              String
  createdAt             DateTime @default(now())

  @@index([profileId, purchaseCreatedAt])
  @@index([profileId, monthKey])
  @@index([contactId])
}

model PaymentServiceConfig {
  id            String            @id @default(cuid())
  service       PaymentServiceKey @unique
  amount        Int
  qrCodeDataUrl String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model AppConfig {
  id        String       @id @default(cuid())
  key       AppConfigKey @unique
  value     String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model VisitSession {
  id             String         @id @default(cuid())
  userId         String?
  user           User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  anonymousId    String?
  startedAt      DateTime
  lastActivityAt DateTime
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  activities     UserActivity[]

  @@index([userId, lastActivityAt])
  @@index([anonymousId, lastActivityAt])
}

model UserActivity {
  id             String       @id @default(cuid())
  userId         String?
  user           User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  visitSessionId String
  visitSession   VisitSession @relation(fields: [visitSessionId], references: [id], onDelete: Cascade)
  type           ActivityType
  path           String?
  createdAt      DateTime     @default(now())

  @@index([userId, createdAt])
  @@index([visitSessionId, createdAt])
}

model PendingSocialOwnershipRequest {
  id               String         @id @default(cuid())
  userId           String
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform         SocialPlatform
  submittedHandle  String
  normalizedHandle String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([userId, platform])
  @@index([platform, normalizedHandle])
}

model NotificationAudienceCounter {
  id            String                       @id @default(cuid())
  category      NotificationAudienceCategory
  subjectUserId String?
  subjectUser   User?                        @relation(fields: [subjectUserId], references: [id], onDelete: Cascade)
  subjectPhone  String?
  count         Int                          @default(0)
  lastChangedAt DateTime?
  createdAt     DateTime                     @default(now())
  updatedAt     DateTime                     @updatedAt
  changes       NotificationAudienceCounterChange[]

  @@unique([category, subjectUserId])
  @@unique([category, subjectPhone])
  @@index([category])
}

model NotificationAudienceCounterChange {
  id            String                      @id @default(cuid())
  counterId     String
  counter       NotificationAudienceCounter @relation(fields: [counterId], references: [id], onDelete: Cascade)
  previousCount Int
  nextCount     Int
  changedAt     DateTime                    @default(now())

  @@index([counterId, changedAt])
}

enum GymTiming {
  MORNING
  EVENING
  BOTH
}

enum LocationCategory {
  COLLEGE
  SCHOOL
  WORKPLACE
  GYM
  NEIGHBOURHOOD
}

enum ConfessionStatus {
  PENDING
  DELIVERED
  OPENED
  REPLIED
  GHOSTED
  EXPIRED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum ConfessionBillingCategory {
  CONFESSION_TO_OTHERS
  CONFESSION_TO_YOURSELF
}

enum ConfessionBillingState {
  FREE
  PAID
}

enum PendingProfileSearchKind {
  PHONE
  INSTAGRAM
  SNAPCHAT
  COLLEGE
  SCHOOL
  WORKPLACE
  GYM
  NEIGHBOURHOOD
}

enum StaffRole {
  ADMIN
  EMPLOYEE
  MARKETING_AGENT
}

enum StaffStatus {
  ACTIVE
  INACTIVE
}

enum StaffPermission {
  MANAGE_USERS
  MANAGE_PAYMENTS
  MANAGE_CONFESSIONS
}

enum PaymentType {
  SEND_CONFESSION
  UNLOCK_CONFESSION_CARD
  UNLOCK_CONFESSION_PAGE
  UNLOCK_PROFILE_INSIGHTS
  SELF_CONFESSION
  IDENTITY_REVEAL
}

enum PaymentServiceKey {
  SEND_CONFESSION
  SELF_CONFESSION
  UNLOCK_CONFESSION_CARD
  UNLOCK_CONFESSION_CARD_WITH_PAGE
  UNLOCK_CONFESSION_PAGE
  UNLOCK_PROFILE_INSIGHTS
  IDENTITY_REVEAL
  IDENTITY_REVEAL_WITH_CARD
  IDENTITY_REVEAL_WITH_PAGE
  IDENTITY_REVEAL_WITH_CARD_AND_PAGE
}

enum AppConfigKey {
  ICONFESS_INSTAGRAM_ID
  ICONFESS_SNAPCHAT_ID
  CONTACT_US_EMAIL
  FEEDBACK_EMAIL
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum ActivityType {
  CLICK
  SCROLL
}

enum SocialPlatform {
  INSTAGRAM
  SNAPCHAT
}

enum NotificationAudienceCategory {
  UNREGISTERED_PHONE_SEARCH
  LOCKED_CONFESSION_RECIPIENT
  PENDING_MUTUAL_REVEAL
}
