generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  publicCode String? @unique
  phone     String   @unique
  username  String?  @unique
  passwordHash String?
  dateOfBirth DateTime?
  instagramHandle String? @unique
  snapchatHandle  String? @unique
  profileSearchCount Int?
  primaryCategory LocationCategory @default(COLLEGE)
  gender    Gender   @default(OTHER)
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  college       CollegeProfile?
  school        SchoolProfile?
  workplace     WorkplaceProfile?
  gym           GymProfile?
  neighbourhood NeighbourhoodProfile?

  sentConfessions     Confession[] @relation("SentConfessions")
  receivedConfessions Confession[] @relation("ReceivedConfessions")

  confessionPageUnlocked Boolean      @default(false)
  unlockedCards          UnlockedCard[]
  profileInsightsViewed  UnlockedProfileInsight[] @relation("ProfileInsightViewer")
  profileInsightsOwned   UnlockedProfileInsight[] @relation("ProfileInsightTarget")
  otpSessions            OtpSession[]
  payments               Payment[]
  visitSessions          VisitSession[]
  activities             UserActivity[]
  pendingSocialOwnershipRequests PendingSocialOwnershipRequest[]
}

model PendingProfileSearchCount {
  id        String                   @id @default(cuid())
  kind      PendingProfileSearchKind
  value     String
  count     Int                      @default(0)
  createdAt DateTime                 @default(now())
  updatedAt DateTime                 @updatedAt

  @@unique([kind, value])
}

model CollegeProfile {
  id            String @id @default(cuid())
  userId        String @unique
  user          User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  collegeName   String
  pinCode       String
  course        String
  branch        String
  yearOfPassing Int
  section       String
  fullName      String
}

model SchoolProfile {
  id               String @id @default(cuid())
  userId           String @unique
  user             User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  schoolName       String
  pinCode          String
  board            String
  yearOfCompletion Int
  section          String
  fullName         String
}

model WorkplaceProfile {
  id           String @id @default(cuid())
  userId       String @unique
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName  String
  department   String
  city         String
  buildingName String
  fullName     String
}

model GymProfile {
  id       String    @id @default(cuid())
  userId   String    @unique
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  gymName  String
  city     String
  pinCode  String
  timing   GymTiming
  fullName String
}

model NeighbourhoodProfile {
  id           String @id @default(cuid())
  userId       String @unique
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  state        String
  city         String
  pinCode      String
  homeNumber   String
  premisesName String
  fullName     String
}

model Confession {
  id          String           @id @default(cuid())
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  senderId    String
  sender      User             @relation("SentConfessions", fields: [senderId], references: [id])
  targetId    String?
  target      User?            @relation("ReceivedConfessions", fields: [targetId], references: [id])
  targetPhone String?
  isSelfConfession Boolean     @default(false)
  billingCategory ConfessionBillingCategory @default(CONFESSION_TO_OTHERS)
  billingState ConfessionBillingState @default(PAID)
  selfGenderOverride Gender?
  message     String
  location    LocationCategory
  matchDetails Json
  status      ConfessionStatus @default(PENDING)
  reply       String?
  repliedAt   DateTime?
  expiresAt   DateTime
  mutualDetected        Boolean  @default(false)
  senderRevealConsent   Boolean  @default(false)
  targetRevealConsent   Boolean  @default(false)
  revealedAt            DateTime?
  unlockedBy  UnlockedCard[]
}

model UnlockedCard {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  confessionId String
  confession   Confession @relation(fields: [confessionId], references: [id])
  unlockedAt   DateTime   @default(now())

  @@unique([userId, confessionId])
}

model UnlockedProfileInsight {
  id           String   @id @default(cuid())
  viewerId     String
  viewer       User     @relation("ProfileInsightViewer", fields: [viewerId], references: [id])
  targetUserId String
  targetUser   User     @relation("ProfileInsightTarget", fields: [targetUserId], references: [id])
  unlockedAt   DateTime @default(now())
  
  @@index([viewerId, targetUserId])
  @@index([targetUserId])
}

model OtpSession {
  id        String   @id @default(cuid())
  phone     String
  otp       String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model StaffUser {
  id           String            @id @default(cuid())
  name         String
  username     String            @unique
  passwordHash String
  role         StaffRole
  status       StaffStatus       @default(ACTIVE)
  permissions  StaffPermission[] @default([])
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  managedPayments Payment[] @relation("PaymentManager")
}

model Payment {
  id                   String        @id @default(cuid())
  userId               String
  user                 User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  type                 PaymentType
  status               PaymentStatus @default(SUCCESS)
  amount               Int
  gateway              String?
  gatewayTransactionId String?
  metadata             Json?
  managedByStaffId     String?
  managedByStaff       StaffUser?    @relation("PaymentManager", fields: [managedByStaffId], references: [id], onDelete: SetNull)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([userId, type, createdAt])
  @@index([status, createdAt])
}

model VisitSession {
  id             String         @id @default(cuid())
  userId         String?
  user           User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  anonymousId    String?
  startedAt      DateTime
  lastActivityAt DateTime
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  activities     UserActivity[]

  @@index([userId, lastActivityAt])
  @@index([anonymousId, lastActivityAt])
}

model UserActivity {
  id             String       @id @default(cuid())
  userId         String?
  user           User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  visitSessionId String
  visitSession   VisitSession @relation(fields: [visitSessionId], references: [id], onDelete: Cascade)
  type           ActivityType
  path           String?
  createdAt      DateTime     @default(now())

  @@index([userId, createdAt])
  @@index([visitSessionId, createdAt])
}

model PendingSocialOwnershipRequest {
  id               String         @id @default(cuid())
  userId           String
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform         SocialPlatform
  submittedHandle  String
  normalizedHandle String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([userId, platform])
  @@index([platform, normalizedHandle])
}

enum GymTiming {
  MORNING
  EVENING
  BOTH
}

enum LocationCategory {
  COLLEGE
  SCHOOL
  WORKPLACE
  GYM
  NEIGHBOURHOOD
}

enum ConfessionStatus {
  PENDING
  DELIVERED
  OPENED
  REPLIED
  GHOSTED
  EXPIRED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum ConfessionBillingCategory {
  CONFESSION_TO_OTHERS
  CONFESSION_TO_YOURSELF
}

enum ConfessionBillingState {
  FREE
  PAID
}

enum PendingProfileSearchKind {
  PHONE
  INSTAGRAM
  SNAPCHAT
}

enum StaffRole {
  ADMIN
  EMPLOYEE
}

enum StaffStatus {
  ACTIVE
  INACTIVE
}

enum StaffPermission {
  MANAGE_USERS
  MANAGE_PAYMENTS
  MANAGE_CONFESSIONS
}

enum PaymentType {
  SEND_CONFESSION
  UNLOCK_CONFESSION_CARD
  UNLOCK_CONFESSION_PAGE
  UNLOCK_PROFILE_INSIGHTS
  SELF_CONFESSION
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum ActivityType {
  CLICK
  SCROLL
}

enum SocialPlatform {
  INSTAGRAM
  SNAPCHAT
}
